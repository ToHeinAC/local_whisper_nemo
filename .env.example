# --- local_whisper_nemo configuration ---
# Copy this file to .env and adjust as needed.

# Hugging Face model id (OpenMDW-1.1, cached under models/)
ASR_MODEL=nvidia/nemotron-3.5-asr-streaming-0.6b

# Language locale (e.g. de-DE, en-US) or "auto" to detect per utterance
ASR_LANGUAGE=auto

# Compute device: auto | cpu | cuda
DEVICE=auto

# Push-to-talk hotkey combination (keyboard library syntax).
# Modifier-only combos work; recording stops when the LAST key listed is released.
HOTKEY=ctrl+shift

# Per-character delay (seconds) when typing text into the focused field
TYPE_DELAY=0.0

# Microphone sample rate (Hz). The model expects 16000.
SAMPLE_RATE=16000
